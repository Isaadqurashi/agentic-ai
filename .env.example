# Required only when DRY_RUN=false.
OPENAI_API_KEY=

# Cost guardrails. Lower this while testing real OpenAI-backed runs.
MAX_SESSION_USD=1.00

# DRY_RUN=true swaps in deterministic fake chat models and performs no OpenAI calls.
DRY_RUN=false

# Optional local roots.
AGENTMESH_WORKSPACE_ROOT=.
AGENTMESH_DATA_DIR=.agentmesh_data
AGENTMESH_RECURSION_LIMIT=12

# SQLite checkpoints are optional while running async A2A servers.
AGENTMESH_ENABLE_SQLITE_CHECKPOINTS=false
